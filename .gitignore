.tmp/
node_modules/
**/node_modules/
.venv/
**/.venv/
dist/
build/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
# Active env files (may contain secrets) — ignored
.env
*/.env
**/.env
# Environment-specific files with real secrets — ignored
.env.prod
*/.env.prod
**/.env.prod
# Safe to commit (no secrets):
# .env.dev       ← committed (SQLite, localhost, no secrets)
# .env.prod.example  ← committed (template with placeholders only)
!.env.dev
!**/.env.dev
!.env.prod.example
!**/.env.prod.example
.vscode/
.DS_Store
coverage/
# Next.js build output
.next/
**/.next/
# pytest cache
.pytest_cache/
**/.pytest_cache/

# Database files (dev.db lives in backend/data/ but must not be committed)
code/backend/data/*.db
code/backend/data/*.db-*
code/backend/data/*.bak

# Log files
*.log
**/*.log

# PID files
*.pid
**/*.pid

# TypeScript build info
*.tsbuildinfo

# pip install typo artifacts (e.g. pip install =0.1.9)
=*
