# ── Production environment template ───────────────────────────────────────────
# Copy this file to .env.prod and fill in real values. NEVER commit .env.prod.
# To use: APP_ENV=prod — config.py loads .env.prod automatically.
#
# Requirements before deploying:
#   pip install psycopg2-binary   (for async PostgreSQL, use asyncpg instead)
#   Or use:  DATABASE_URL=postgresql+asyncpg://...

APP_ENV=prod

# PostgreSQL — Neon, Supabase, RDS, etc.
# Async driver options:
#   asyncpg  → postgresql+asyncpg://user:pass@host/db?ssl=require
#   psycopg3 → postgresql+psycopg://user:pass@host/db
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require

# JWT — generate a strong random secret:  openssl rand -base64 32
JWT_SECRET=CHANGE_ME

# Must be your actual production domain — localhost is rejected at startup
FRONTEND_CORS_ORIGINS=https://your-domain.com

# AI — LLM inference (provider-agnostic: anthropic or groq)
# Note (Phase 4.1.2): previously configured for OZ (Warp cloud agent). Now uses LLMClient directly.
LLM_PROVIDER=anthropic
LLM_API_KEY=CHANGE_ME
LLM_MODEL_ID=claude-3-5-haiku-latest
AI_ENABLED=true

# Rate limit caps (enforced in service layer)
LLM_MAX_CONTEXT_CHARS=8000
LLM_MAX_SYNTHESIS_PER_WEEK=3
LLM_MAX_SUGGESTIONS_PER_DAY=5
LLM_MAX_COPLAN_PER_DAY=3

# Optional tuning
ACCESS_TOKEN_EXPIRE_MINUTES=60
