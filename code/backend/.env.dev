# ── Dev environment — SQLite, localhost only ──────────────────────────────────
# This file is safe to commit. It contains no secrets — only dev-safe defaults.
# To use: APP_ENV=dev (default) — loaded automatically by config.py.

APP_ENV=dev
DATABASE_URL=sqlite+aiosqlite:///./data/dev.db
JWT_SECRET=dev-secret-change-me
FRONTEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# AI — set OZ_API_KEY to enable; leave blank to run with AI disabled
OZ_API_KEY=
OZ_MODEL_ID=anthropic/claude-haiku-4
AI_ENABLED=true
