# Production environment configuration
# Copy to .env.prod and fill in actual values — NEVER commit .env.prod to git.
#
# Required for Railway deployment. Set each key as a Railway environment variable
# (or paste the contents of .env.prod into the Railway "Variables" panel).

APP_ENV=prod

# PostgreSQL connection string from Neon (pooled endpoint)
# Format: postgresql+asyncpg://<user>:<pass>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require

# Generate with: openssl rand -hex 32
JWT_SECRET=<generate-a-strong-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Production frontend domain — no trailing slash, no localhost
FRONTEND_CORS_ORIGINS=https://<your-vercel-domain>.vercel.app

# LLM / AI inference
LLM_PROVIDER=anthropic
LLM_API_KEY=<your-anthropic-or-groq-api-key>
LLM_MODEL_ID=claude-3-5-haiku-latest
AI_ENABLED=true
LLM_MAX_CONTEXT_CHARS=8000

# Rate limits
LLM_MAX_SYNTHESIS_PER_WEEK=3
LLM_MAX_SUGGESTIONS_PER_DAY=5
LLM_MAX_COPLAN_PER_DAY=3
